package com.kh.constant;

/*
 * 상수 -> 변하지 않는 값
 * 
 */
public class Constant {
	public static void main(String[] args){
		
		System.out.println(7);
		System.out.println(-7);
		System.out.println("-------------------");
		
		// 실수()
		System.out.println(7.7);
		System.out.println(-7.7);
		System.out.println("-------------------");
		
		// (단일)문자, 문자열
		System.out.println('돈');
		System.out.println();
	}
}
