	// 변수를 사용하는 방법에 대해서 알아봅시다 
	public void declareVariable() {
		/*
		 * 변수 선언방법
		 * 
		 * int price;
		 * 
		 * 자료형(DataType) 변수식별자; 
		 * 변수를 만들고 처음 값을 넣는것은 초기화// 초기화를 통해 넣는 값을 초기값
		 * 변수는 자신이 선언된 {Scope} 에서만 사용 
		 * local variable(지역변수)
		 * 
		 * 
		 * 명명법
		 * 식별자(Identifier)
		 * 클래스명, 메소드명, 변수명 등 개발자가 만들어서 이용하는 고유의 이름
		 * 
		 * 식별자를 만들때 꼭 지켜야 하는 규칙
		 * - (keyword)예약어를 식별자로 쓰면 안됨
		 * - 공백은 포함할 수 없음
		 * - 대소문자를 구분하고 길이 제한은 없음
		 * - 특수문자는 _, $ 만 쓸수 있다
		 * - 숫자가 먼저올수 없음
		 * 
		 * 개발자들끼리의 암묵적인 약속
		 * - 영어만 사용
		 * 클래스 / 인터페이스 명명 규칙
		 * - 첫글자는 대문자로 표기
		 * - 연결된 단어들의 첫 글자도 대문자로 표기
		 * - 명사, 형용사를 서술적으로 연결해서 사용
		 * 
		 * 변수 명명 규칙
		 * - 명사적 의미를 갖게 만들어 줌
		 * - 첫 글자를 소문자로 표기, 연결된 단어들의 첫글자를 대문자로 표기 
		 * - phonNumber
		 * 
		 * 메소드 명명 규칙
		 * - 동사적 의미를 갖게 만들어줌
		 * - 첫글자를 소문자로 표기, 연결된 단어들의 첫글자를 대문자로
		 * - 메소드 식별자의 경우 식별자 뒤에 반드시 한 쌍의 "()"를 붙임
		 * - 메소드에는 일반적으로 _를 사용하지 않음
		 * -> join(), signUp()
		 * 
		 * 상수 명명 규칙
		 * - 모든 문자를 대문자로 표기
		 * - 단어와 단어 사이를 _를 사용해서 구분한다
		 * - LOGIN_OK
		 * - 변수에 값을 대입하고 출력하기 위해서는 선언 및 초기화 작업이 필요함
		 * 
		 * 변수의 자료형
		 * Java의 기본자료형, 원시자료형(Primitive Type)
		 * 
		 * 논리 자료형(true / false)
		 * 변수선언 : 자료형 변수식별자;
		 * 지역변수는 초기화를 하지 않으면 사용할 수 없음
		 * 
		 * 
		 * 숫자 자료형
		 * 정수형
		 * - 4가지 종류
		 * byte (1), short(2), int(4), long(8)형이 있음(단위 byte)
		 * 
		 * 정수형 
		 * 대부분 int 쓰임
		 * long 을 사용할 때는 대입할 숫자 뒤에 "L"을 붙인다
		 * 예시)
		 * long longNumber = 4L;
		 * 정수형에서 자바가 기본적으로 인식하는건 int 형
		 * 
		 *  실수형
		 * float (4), double (8)
		 * 실수는 자바가 기본적으로 인식하는건 double 형
		 * float floatNumber = 2.22F;
		 * 예시)
		 * double doubleNumber = 3.33D;
		 * 
		 * 
		 * Byte 와 bit
		 * 불이 꺼지고 켜지는게 1비트
		 * 1바이트 = 8비트
		 * 
		 * 단일 문자형
		 * char money = '돈'; // 2Byte
		 * 
		 * 문자열 : 참조자료형
		 * String str = "문자열";
		 * 
		 */
		
		int price; // 변수 선언 
		
		boolean isTrue = true; // 변수 선언 및 초기화 // 이때 오른쪽에서 대입하는 값을 ~자료형리터럴 이라 한다
		System.out.println(isTrue);
		isTrue = false; // 변수의 값을 대입
		System.out.println(isTrue);
		
		byte byteNumber = 0;
		short shortNumber = 1;
		int intNumber = 2;
		long longNumber = 4L;
		
		float floatNumber = 2.22F;
		double doubleNumber = 3.33D;
		char charText = '돈';
		String str = "문자열";
		
		System.out.println("정수 자료형 (byte) : " +  byteNumber);
		System.out.println("정수 자료형 (short) : " + shortNumber);
		System.out.println("정수 자료형 (int) : " + intNumber);
		System.out.println("정수 자료형 (long) : " + longNumber);
		
		System.out.println("실수 자료형 (float) : " +  floatNumber);
		System.out.println("실수 자료형 (double) : " +  doubleNumber);
		
		System.out.println("문자 자료형 (char) : " +  charText);
		System.out.println("문자열 자료형 (String) : " +  str);
		
		// 출력문의 종류
		// System.out.print();
		// System.out.println(); => 개행한다
		// System.out.printf();
		
	}
}